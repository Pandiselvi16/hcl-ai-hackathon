{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Storage Tier",
  "type": "object",
  "required": [
    "name",
    "status"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "max_iops": {
      "type": "integer"
    },
    "max_throughput_mbps": {
      "type": "integer"
    },
    "encryption": {
      "type": "boolean"
    },
    "replication": {
      "type": "string",
      "enum": [
        "zone",
        "region",
        "geo"
      ]
    },
    "price_per_gb_month_usd": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "preview"
      ]
    }
  }
}
