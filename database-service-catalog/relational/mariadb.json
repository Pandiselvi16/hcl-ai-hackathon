{
  "engine": "MariaDB",
  "description": "Managed MariaDB database service",
  "versions": [
    {
      "version": "10.11",
      "status": "active",
      "end_of_support": "2028-02-16",
      "features": [
        "system_versioning",
        "sequences",
        "json_functions"
      ]
    },
    {
      "version": "11.4",
      "status": "active",
      "end_of_support": "2029-05-29",
      "features": [
        "system_versioning",
        "sequences",
        "json_functions",
        "vector"
      ]
    }
  ],
  "instance_classes": [
    {
      "name": "db-small",
      "vcpus": 2,
      "memory_gb": 4,
      "max_connections": 150,
      "max_storage_gb": 500,
      "price_per_hour_usd": 0.055
    },
    {
      "name": "db-medium",
      "vcpus": 4,
      "memory_gb": 8,
      "max_connections": 500,
      "max_storage_gb": 1000,
      "price_per_hour_usd": 0.11
    },
    {
      "name": "db-large",
      "vcpus": 8,
      "memory_gb": 32,
      "max_connections": 1000,
      "max_storage_gb": 5000,
      "price_per_hour_usd": 0.33
    }
  ],
  "features": {
    "high_availability": true,
    "read_replicas": true,
    "max_read_replicas": 3,
    "automated_backups": true,
    "encryption_at_rest": true
  },
  "regions": [
    "us-east-1",
    "us-west-1",
    "eu-west-1",
    "eu-central-1"
  ]
}
