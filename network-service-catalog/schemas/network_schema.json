{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Network Service",
  "type": "object",
  "required": [
    "name",
    "description",
    "status"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "preview"
      ]
    },
    "price_per_hour_usd": {
      "type": "number",
      "minimum": 0
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
