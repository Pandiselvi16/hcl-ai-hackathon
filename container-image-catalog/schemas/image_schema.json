{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Container Image",
  "type": "object",
  "required": [
    "name",
    "registry",
    "repository",
    "tag",
    "os",
    "architecture",
    "status"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "registry": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "tag": {
      "type": "string"
    },
    "digest": {
      "type": "string"
    },
    "os": {
      "type": "string"
    },
    "architecture": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "size_mb": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "preview"
      ]
    }
  }
}
