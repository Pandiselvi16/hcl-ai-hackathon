{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cloud Region",
  "type": "object",
  "required": [
    "name",
    "display_name",
    "availability_zones",
    "status",
    "services"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z]+-[a-z]+-[0-9]+$"
    },
    "display_name": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "availability_zones": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "coming-soon"
      ]
    },
    "launched": {
      "type": "string",
      "format": "date"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compliance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
