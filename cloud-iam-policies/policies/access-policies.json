{
  "description": "Organization-wide access policies",
  "policies": [
    {
      "name": "enforce-mfa",
      "description": "Require MFA for all console access",
      "effect": "enforce",
      "conditions": {
        "access_type": "console"
      },
      "action": "require-mfa",
      "status": "active"
    },
    {
      "name": "restrict-public-access",
      "description": "Prevent creating publicly accessible resources",
      "effect": "deny",
      "conditions": {
        "resource_visibility": "public"
      },
      "exceptions": [
        "cdn",
        "load-balancer"
      ],
      "status": "active"
    },
    {
      "name": "require-encryption",
      "description": "All storage must be encrypted at rest",
      "effect": "enforce",
      "conditions": {
        "resource_type": [
          "storage",
          "database",
          "disk"
        ]
      },
      "action": "require-encryption",
      "status": "active"
    },
    {
      "name": "geo-restriction",
      "description": "Restrict resource creation to approved regions",
      "effect": "deny",
      "conditions": {
        "region_not_in": [
          "us-east-1",
          "us-west-1",
          "eu-west-1",
          "eu-central-1",
          "ap-south-1",
          "ap-southeast-1"
        ]
      },
      "status": "active"
    },
    {
      "name": "tagging-policy",
      "description": "Resources must have required tags",
      "effect": "enforce",
      "required_tags": [
        "environment",
        "team",
        "project",
        "cost-center"
      ],
      "status": "active"
    }
  ]
}
