{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert Rule",
  "type": "object",
  "required": [
    "name",
    "description",
    "severity",
    "expression",
    "status"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ]
    },
    "expression": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "disabled",
        "preview"
      ]
    }
  }
}
