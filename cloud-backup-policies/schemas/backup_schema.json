{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Backup Policy",
  "type": "object",
  "required": [
    "name",
    "description",
    "resource_type",
    "schedule",
    "retention",
    "status"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "resource_type": {
      "type": "string"
    },
    "schedule": {
      "type": "object"
    },
    "retention": {
      "type": "object"
    },
    "cross_region": {
      "type": "boolean"
    },
    "encryption": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "draft"
      ]
    }
  }
}
